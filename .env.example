# -----------------------------------------------------------------------------
# ⚙️ LOCAL DEVELOPMENT CONFIGURATION
# -----------------------------------------------------------------------------
# Welcome! To run this project locally, you need to configure an API key.
# Please follow these steps:
# 1. Copy this file and rename it to `.env` (don't delete this example file!)
# 2. Choose ONE of the two options below and fill in your details.
# 
# Note: For production deployment, you don't need this file—these values 
# are automatically set via the deploy commands.

# =============================================================================
# OPTION 1: Gemini API Key (Recommended for quick start & beginners)
# =============================================================================
# Easiest way to get started! Get your free API key here:
# 👉 https://aistudio.google.com/app/apikey
#
# To use this option:
# - Uncomment the GEMINI_API_KEY line below and paste your key.
# - Comment out all the lines in OPTION 2 below.

# GEMINI_API_KEY=your-api-key-here


# =============================================================================
# OPTION 2: Google Cloud Vertex AI (For enterprise/production GCP projects)
# =============================================================================
# Use this if you are developing against a specific Google Cloud Project.
#
# To use this option:
# - Leave the three lines below uncommented.
# - Replace 'your-gcp-project-id' with your actual GCP Project ID.

GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
